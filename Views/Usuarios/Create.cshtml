@model WebApplication1.Models.Usuario

@{
    ViewData["Title"] = "Cadastrar Usuário";
}

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                ← Início
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                Lista de Usuários
            </a>
            <span class="badge ms-auto px-3 py-2" style="background:#5B7CFA;">👤 Cadastro de Usuário</span>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header text-white" style="background:#5B7CFA;">
                <h5 class="mb-0 fw-semibold">Novo Usuário</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="Perfil" value="Cliente" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nome" class="form-label fw-semibold"></label>
                            <input asp-for="Nome" class="form-control" placeholder="João" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Sobrenome" class="form-label fw-semibold"></label>
                            <input asp-for="Sobrenome" class="form-control" placeholder="Silva" />
                            <span asp-validation-for="Sobrenome" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" placeholder="joao@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Cpf" class="form-label fw-semibold"></label>
                            <input asp-for="Cpf" class="form-control" placeholder="000.000.000-00" />
                            <span asp-validation-for="Cpf" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefone" class="form-label fw-semibold"></label>
                            <input asp-for="Telefone" class="form-control" placeholder="(11) 99999-0000" />
                            <span asp-validation-for="Telefone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Senha" class="form-label fw-semibold"></label>
                            <input asp-for="Senha" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Senha" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Confirmar Senha</label>
                            <input type="password" class="form-control" placeholder="••••••••" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn text-white px-4" style="background:#5B7CFA;">
                            ✅ Cadastrar Usuário
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            ← Voltar ao Início
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
