<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vizi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        * {
            margin: 0;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 1.5;
        }

        body {
            background-color: #EEF1FB;
            color: #3a3a5c;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Header / Navbar ── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 100px;
            background-color: #6B8DF2;
            height: 4pc;
        }

        .Logo {
            height: 5pc;
            width: auto;
            filter: contrast(1.1);
        }

        .navegacao {
            font-size: 16px;
            font-weight: 300;
        }

        .Sino {
            height: 1.8pc;
            width: auto;
            filter: brightness(1.2) contrast(1.1);
            justify-content: center;
            margin-top: 8px;
        }

        .EntrarH {
            border: 1px solid white;
            padding: 8px 20px;
            border-radius: 5px;
            font-size: 16px;
            font-weight: 300;
            color: white;
            text-decoration: none;
            background: transparent;
        }

        .EntrarH:hover {
            background: rgba(255,255,255,0.15);
            color: white;
        }

        .menu {
            display: flex;
            align-items: center;
            gap: 50px;
        }

        .menu a {
            text-decoration: none;
            color: white;
            font-size: 16px;
            font-weight: 300;
        }

        .menu a:hover {
            color: rgba(255,255,255,0.8);
        }

        /* ── Cards ── */
        .card {
            border: none;
            box-shadow: 0 2px 12px rgba(91,124,250,0.08);
            border-radius: 14px;
        }

        .card-header {
            border-radius: 14px 14px 0 0 !important;
        }

        /* ── Buttons ── */
        .btn {
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-primary {
            background-color: #5B7CFA;
            border-color: #5B7CFA;
        }

        .btn-primary:hover {
            background-color: #4A6AE8;
            border-color: #4A6AE8;
        }

        /* ── Table ── */
        .table th {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── Alerts ── */
        .alert {
            border-radius: 10px;
            border: none;
        }

        /* ── Footer ── */
        .footer {
            margin-top: auto;
            background-color: #1c1c1c;
            padding: 0.75rem 0;
            font-size: 0.78rem;
            color: #aaa;
        }

        .footer .footer-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 100px;
        }

        /* ── Decorações ── */
        .dot-pattern {
            position: fixed;
            width: 110px;
            height: 110px;
            background-image: radial-gradient(circle, #b0bcf7 1.5px, transparent 1.5px);
            background-size: 14px 14px;
            opacity: 0.55;
            pointer-events: none;
            z-index: 0;
        }
        .dot-tl { top: 40px; left: 20px; }
        .dot-br { bottom: 60px; right: 20px; }

        .circle-deco {
            position: fixed;
            border-radius: 50%;
            background: rgba(180,195,252,0.25);
            pointer-events: none;
            z-index: 0;
        }
        .circle-tr { width: 120px; height: 120px; top: 30px; right: -30px; }
        .circle-bl { width: 90px; height: 90px; bottom: 80px; left: -20px; }

        .container { position: relative; z-index: 1; }
    </style>
</head>
<body>

    <div class="dot-pattern dot-tl"></div>
    <div class="dot-pattern dot-br"></div>
    <div class="circle-deco circle-tr"></div>
    <div class="circle-deco circle-bl"></div>

    <header class="header">
        <a asp-controller="Home" asp-action="Index">
            <img src="~/images/LogoVizi.png" alt="Vizi" class="Logo" />
        </a>

        <nav class="menu navegacao">
            <a asp-controller="Home" asp-action="Index">Início</a>
            <a asp-controller="Usuarios" asp-action="Index">Usuários</a>
            <a asp-controller="Empresas" asp-action="Index">Empresas</a>
            <a href="#"><img src="~/images/sino.png" alt="Notificações" class="Sino" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"/><i class="bi bi-bell" style="color:white; font-size:1.3rem;"></i></a>
            <a asp-controller="Account" asp-action="Login" class="EntrarH">Entrar</a>
        </nav>
    </header>

    <div class="container mt-4 mb-5">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <span>@TempData["Sucesso"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="footer">
        <div class="footer-inner">
            <span>&copy; Vizi @DateTime.Now.Year — Todos os direitos reservados.</span>
            <span>contato: vizi.dto@@gmail.com</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
