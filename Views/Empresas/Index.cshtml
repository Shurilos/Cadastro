@model IEnumerable<WebApplication1.Models.Empresa>

@{
    ViewData["Title"] = "Empresas";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">← Início</a>
    <h4 class="mb-0 ms-2 fw-semibold">🏢 Empresas</h4>
    <a asp-action="Create" class="btn btn-success btn-sm ms-auto">+ Nova Empresa</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhuma empresa cadastrada ainda.</div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Razão Social</th>
                        <th>CNPJ</th>
                        <th>E-mail</th>
                        <th>Segmento</th>
                        <th>Porte</th>
                        <th>Cadastro</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.RazaoSocial</td>
                            <td>@item.Cnpj</td>
                            <td>@item.Email</td>
                            <td>@item.Segmento</td>
                            <td><span class="badge bg-secondary">@item.Porte</span></td>
                            <td>@item.DataCadastro.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Ver</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
