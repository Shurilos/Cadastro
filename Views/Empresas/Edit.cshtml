@model WebApplication1.Models.Empresa

@{
    ViewData["Title"] = "Editar Empresa";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">← Início</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Lista de Empresas</a>
            <span class="badge bg-warning text-dark ms-auto px-3 py-2">✏️ Editar Empresa</span>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0 fw-semibold">Editar: @Model.RazaoSocial</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="DataCadastro" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="RazaoSocial" class="form-label fw-semibold"></label>
                            <input asp-for="RazaoSocial" class="form-control" />
                            <span asp-validation-for="RazaoSocial" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Cnpj" class="form-label fw-semibold"></label>
                            <input asp-for="Cnpj" class="form-control" />
                            <span asp-validation-for="Cnpj" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefone" class="form-label fw-semibold"></label>
                            <input asp-for="Telefone" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Senha" class="form-label fw-semibold"></label>
                            <input asp-for="Senha" class="form-control" type="password" placeholder="Digite a nova senha" />
                            <span asp-validation-for="Senha" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Segmento" class="form-label fw-semibold"></label>
                            <select asp-for="Segmento" class="form-select">
                                <option value="">Selecione...</option>
                                <option>Consultoria</option>
                                <option>Desenvolvimento de Software</option>
                                <option>Marketing Digital</option>
                                <option>Contabilidade</option>
                                <option>Jurídico</option>
                                <option>Logística</option>
                                <option>Financeiro</option>
                                <option>Recursos Humanos</option>
                                <option>Segurança</option>
                                <option>Limpeza e Conservação</option>
                                <option>Manutenção</option>
                                <option>Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Porte" class="form-label fw-semibold"></label>
                            <select asp-for="Porte" class="form-select">
                                <option value="">Selecione...</option>
                                <option>MEI</option>
                                <option>Pequeno</option>
                                <option>Médio</option>
                                <option>Grande</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Endereco" class="form-label fw-semibold"></label>
                            <input asp-for="Endereco" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Cidade" class="form-label fw-semibold"></label>
                            <input asp-for="Cidade" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Estado" class="form-label fw-semibold"></label>
                            <select asp-for="Estado" class="form-select">
                                <option value="">UF</option>
                                <option>AC</option><option>AL</option><option>AP</option><option>AM</option>
                                <option>BA</option><option>CE</option><option>DF</option><option>ES</option>
                                <option>GO</option><option>MA</option><option>MT</option><option>MS</option>
                                <option>MG</option><option>PA</option><option>PB</option><option>PR</option>
                                <option>PE</option><option>PI</option><option>RJ</option><option>RN</option>
                                <option>RS</option><option>RO</option><option>RR</option><option>SC</option>
                                <option>SP</option><option>SE</option><option>TO</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning px-4 text-dark fw-semibold">💾 Salvar Alterações</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
